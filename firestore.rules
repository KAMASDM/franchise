// Firestore Security Rules — Production
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function currentViews() {
      return resource.data.views == null ? 0 : resource.data.views;
    }

    function isBlogViewIncrement() {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly(['views'])
        && request.resource.data.views == currentViews() + 1;
    }

    // Only the fields we expect are present on a brand-view document
    function isValidBrandView() {
      let allowed = ['brandId', 'viewedAt', 'userId', 'sessionId'];
      return request.resource.data.keys().hasOnly(allowed);
    }

    // Validate contact/lead form submissions — limit size to prevent flooding
    function isValidPublicSubmission() {
      return request.resource.data.size() <= 30;
    }

    // --- Collection Rules ---

    match /admins/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      allow write: if false;
    }

    match /users/{userId} {
      allow get: if request.auth.uid == userId || isAdmin();
      allow list: if isAdmin();
      allow create, update: if request.auth.uid == userId || isAdmin();
    }

    match /users/{userId}/notifications/{notificationId} {
      allow read, write: if request.auth.uid == userId || isAdmin();
      // Allow authenticated users to create notifications for other users (e.g. brand submission alerts)
      allow create: if isSignedIn();
    }

    match /brands/{brandId} {
      allow get: if resource.data.status == 'active' || isAdmin()
        || (isSignedIn() && request.auth.uid == resource.data.userId);
      allow list: if true;
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.userId;
      allow update: if isSignedIn() && (request.auth.uid == resource.data.userId || isAdmin());
      allow delete: if isAdmin();
    }

    match /brandfranchiseInquiry/{inquiryId} {
      // Public can submit franchise inquiries; validate field count to limit abuse
      allow create: if isValidPublicSubmission();
      allow get: if isSignedIn() && (request.auth.uid == resource.data.brandOwnerId || isAdmin());
      allow list: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /brandViews/{brandId} {
      allow get: if isSignedIn() && (request.auth.uid == resource.data.brandOwnerId || isAdmin());
      allow list: if isSignedIn();
      // Allow anonymous view tracking but validate written fields to prevent data abuse
      allow create, update: if isValidBrandView();
      allow delete: if isAdmin();
    }

    match /contactUs/{contactId} {
      allow create: if isValidPublicSubmission();
      allow read, update, delete: if isAdmin();
    }

    match /chatLeads/{leadId} {
      allow create: if isValidPublicSubmission();
      allow read, update, delete: if isAdmin();
    }

    match /testimonials/{testimonialId} {
      allow read: if true;
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.userId;
      allow update, delete: if isSignedIn() && (request.auth.uid == resource.data.userId || isAdmin());
    }

    match /videoTestimonials/{testimonialId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /aboutUs/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /blogs/{blogId} {
      allow read: if resource.data.status == 'published' || isAdmin();
      allow list: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || isBlogViewIncrement();
    }

    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /faqs/{faqId} {
      allow read: if true;
      // Only authenticated brand owners can create FAQs for their own brand
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.userId;
      allow update, delete: if isSignedIn() && (request.auth.uid == resource.data.userId || isAdmin());
    }

    // Email logs — only authenticated flows write; admins read
    match /emailLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // Location Finder — Saved Locations
    match /savedLocations/{locationId} {
      allow read: if isSignedIn() && request.auth.uid == resource.data.userId;
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.userId;
      allow update, delete: if isSignedIn() && request.auth.uid == resource.data.userId;
    }

    // Location Finder — Search History
    match /searchHistory/{historyId} {
      allow read: if isSignedIn() && request.auth.uid == resource.data.userId;
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.userId;
      allow delete: if isSignedIn() && request.auth.uid == resource.data.userId;
    }

    // Default deny all other collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}